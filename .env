# ── General ──────────────────────────────────────────────
APP_NAME=VEDA
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ── ChromaDB Memory ───────────────────────────────────────
CHROMADB_PATH=./memory/chromadb
CHROMADB_COLLECTION=veda_research

# ── Hindsight — DISABLED (using ChromaDB instead) ────────
# Hindsight memory for Vectorize demo
HINDSIGHT_ENABLED=true
HINDSIGHT_MODE=local
HINDSIGHT_LOCAL_URL=http://localhost:8888
HINDSIGHT_BANK_ID=veda
HINDSIGHT_RECALL_TOP_K=5
HINDSIGHT_REFLECT_EVERY_N=3
HINDSIGHT_TIMEOUT_SECONDS=5
HINDSIGHT_CONNECT_TIMEOUT_SECONDS=0.35

# ── LLM — Ollama only, no cloud ──────────────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b
OLLAMA_RESEARCH_MODEL=gemma2:2b
OLLAMA_VISION_MODEL=gemma2:2b
OLLAMA_FALLBACK_MODEL=gemma2:2b
OLLAMA_TIMEOUT=20

TEMPERATURE=0.1
MAX_TOKENS=2000

# ── LangGraph ────────────────────────────────────────────
CHECKPOINT_DB_PATH=./memory/checkpoints.db

# ── Voice — pyttsx3 is 100% offline ──────────────────────
ENABLE_VOICE=true
VOICE_MODEL=pyttsx3
WAKE_WORD=hey veda
# Optional: set this if Windows chooses the wrong mic. Current default was device 1.
# VOICE_INPUT_DEVICE_INDEX=1
STT_MODEL_SIZE=base
STT_COMMAND_MAX_SECONDS=6
STT_COMMAND_MIN_SECONDS=1
STT_SILENCE_SECONDS=0.8
STT_SPEECH_RMS_THRESHOLD=0.018
TTS_RATE=175

# ── Dashboard ─────────────────────────────────────────────
DASHBOARD_PORT=8765
PHONE_MIC_PORT=8766
