# ════════════════════════════════════════════════════════════════════════════════
# VEDA Configuration — Copy to .env and customize for your deployment
# ════════════════════════════════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────────────────────────────────
APP_NAME=VEDA
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ── ChromaDB Memory (Research Documents) ─────────────────────────────────────────
CHROMADB_PATH=./memory/chromadb
CHROMADB_COLLECTION=veda_research

# ── Hindsight (Vectorize) Agent Memory ───────────────────────────────────────────
# Choose mode: "local" (self-hosted Docker) or "cloud" (Hindsight Cloud free tier)
HINDSIGHT_MODE=local
HINDSIGHT_LOCAL_URL=http://localhost:8888
HINDSIGHT_CLOUD_URL=https://api.hindsight.vectorize.io
HINDSIGHT_API_KEY=

# Optional: If using cloud mode, get your API key from https://hindsight.vectorize.io
# HINDSIGHT_API_KEY=your_hindsight_cloud_key_here

HINDSIGHT_BANK_ID=veda
HINDSIGHT_RECALL_TOP_K=5
HINDSIGHT_REFLECT_EVERY_N=10
HINDSIGHT_ENABLED=true

# ── LLM Configuration ────────────────────────────────────────────────────────────
# Provider: "ollama" (local, offline), "openai" (cloud), or "anthropic" (cloud)
LLM_PROVIDER=ollama
LLM_MODEL=mistral

# Ollama Configuration (Local Models — 100% Offline)
# Models: mistral, neural-chat, llama2, dolphin-mixtral, starling-lm, etc.
# To pull a model: ollama pull mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# OpenAI Configuration (Optional — for cloud usage)
# Leave blank to use local Ollama instead
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo

# Anthropic Configuration (Optional — for cloud usage)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus

# Common LLM Settings
TEMPERATURE=0.7
MAX_TOKENS=2000
TOP_P=0.95
TOP_K=40

# ── LangGraph Checkpointing ──────────────────────────────────────────────────────
CHECKPOINT_DB_PATH=./memory/checkpoints.db
CHECKPOINT_THREAD_ID=default

# ── Voice & I/O ──────────────────────────────────────────────────────────────────
ENABLE_VOICE=true
VOICE_MODEL=eleven_labs
VOICE_LANGUAGE=en
